{
  "rules": {
    "config": {
      "adminPin": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || newData.exists())",
        ".validate": "newData.isString() && newData.val().length >= 10"
      },
      "$other": {
        ".validate": false
      }
    },
    "admins": {
      ".read": true,
      "$adminId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'pin'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
        "pin": { ".validate": "newData.isString() && newData.val().length >= 10" },
        "$other": { ".validate": false }
      }
    },
    "tournaments": {
      ".read": true,
      "$tournamentId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'type', 'status'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "type": { ".validate": "newData.isString() && (newData.val() === 'individual' || newData.val() === 'team')" },
        "status": { ".validate": "newData.isString() && (newData.val() === 'draft' || newData.val() === 'in_progress' || newData.val() === 'completed' || newData.val() === 'cancelled')" }
      }
    },
    "matches": {
      ".read": true,
      "$tournamentId": {
        ".write": "auth != null",
        "$matchId": {
          ".validate": "newData.hasChildren(['tournamentId', 'status']) && (!data.exists() || !data.child('updatedAt').exists() || !newData.child('updatedAt').exists() || newData.child('updatedAt').val() > data.child('updatedAt').val())",
          "status": { ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'in_progress' || newData.val() === 'completed')" },
          "$other": { ".validate": true }
        }
      }
    },
    "tournamentPlayers": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "tournamentReferees": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "teams": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "schedule": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "players": {
      ".read": true,
      "$playerId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
        "$other": { ".validate": false }
      }
    },
    "referees": {
      ".read": true,
      "$refereeId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'pin'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
        "pin": { ".validate": "newData.isString() && newData.val().length >= 10" },
        "$other": { ".validate": false }
      }
    },
    "courts": {
      ".read": true,
      "$courtId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
        "$other": { ".validate": false }
      }
    },
    "notifications": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "pushSubscriptions": {
      ".read": true,
      "$tokenKey": {
        ".write": true,
        ".validate": "newData.hasChildren(['token', 'favoriteIds', 'platform', 'updatedAt'])",
        "token": { ".validate": "newData.isString()" },
        "favoriteIds": { ".validate": true },
        "platform": { ".validate": "newData.isString()" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "pushNotifSent": {
      ".read": false,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
