{
  "rules": {
    "config": {
      "adminPin": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || newData.exists())",
        ".validate": "newData.isString() && newData.val().length >= 10"
      },
      "$other": {
        ".validate": false
      }
    },
    "admins": {
      ".read": "auth != null",
      "$adminId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'pin']) && newData.child('name').isString() && newData.child('pin').isString() && newData.child('pin').val().length >= 10"
      }
    },
    "tournaments": {
      ".read": true,
      "$tournamentId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name', 'status']) && newData.child('name').isString() && newData.child('status').isString()"
      }
    },
    "matches": {
      ".read": true,
      "$tournamentId": {
        ".write": "auth != null",
        "$matchId": {
          ".validate": "newData.hasChildren(['tournamentId', 'status']) && (!data.exists() || !data.child('updatedAt').exists() || !newData.child('updatedAt').exists() || newData.child('updatedAt').val() > data.child('updatedAt').val())",
          "status": { ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'in_progress' || newData.val() === 'completed')" },
          "tournamentId": { ".validate": "newData.isString()" },
          "type": { ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'individual' || newData.val() === 'team'))" },
          "$other": { ".validate": true }
        }
      }
    },
    "tournamentPlayers": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "tournamentReferees": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "teams": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "schedule": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "players": {
      ".read": true,
      "$playerId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name']) && newData.child('name').isString()"
      }
    },
    "referees": {
      ".read": "auth != null",
      "$refereeId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name']) && newData.child('name').isString()"
      }
    },
    "courts": {
      ".read": true,
      "$courtId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name']) && newData.child('name').isString()"
      }
    },
    "notifications": {
      ".read": true,
      "$tournamentId": { ".write": "auth != null" }
    },
    "pushSubscriptions": {
      ".read": true,
      "$tokenKey": {
        ".write": true,
        ".validate": "newData.hasChildren(['token', 'favoriteIds', 'platform', 'updatedAt'])",
        "token": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "favoriteIds": { ".validate": true },
        "favoriteNames": { ".validate": true },
        "platform": { ".validate": "newData.isString() && newData.val().length <= 50" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "pushNotifSent": {
      ".read": false,
      ".write": "auth != null"
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
